<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        Uygulama Mac App Store dışında dağıtılıyor; sandbox kapalı.
        Sandbox açıkken global hotkey ⌘C simülasyonu ile başka
        uygulamalardaki seçimi panoya alamıyor.
    -->
    <key>com.apple.security.cs.allow-jit</key>
    <false/>
</dict>
</plist>
